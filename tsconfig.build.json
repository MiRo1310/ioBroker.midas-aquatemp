// Specialized tsconfig to only compile .ts-files in the src dir
{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"allowJs": false,
		"checkJs": false,
		"noEmit": false,
		"declaration": false
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts"]
}
